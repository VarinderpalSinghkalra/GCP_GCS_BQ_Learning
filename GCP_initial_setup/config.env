# ==========================
# REQUIRED
# ==========================

PROJECT_ID="my-new-project-123"
BILLING_ACCOUNT="XXXXXX-XXXXXX-XXXXXX"

# Optional
# ORG_ID="123456789012"
# FOLDER_ID="345678901234"

# ==========================
# DEFAULT SETTINGS
# ==========================

DEFAULT_REGION="asia-south2"
DEFAULT_ZONE="asia-south2-a"

VPC_NAME="vpc-main"
SUBNET_NAME="subnet-asia-south2"
SUBNET_CIDR="10.10.0.0/16"

ALLOW_SSH_CIDR="0.0.0.0/0"
ALLOW_RDP_CIDR="0.0.0.0/0"

# ==========================
# APIs TO ENABLE
# ==========================

APIS=(
serviceusage.googleapis.com
cloudresourcemanager.googleapis.com
iam.googleapis.com
iamcredentials.googleapis.com
compute.googleapis.com
container.googleapis.com
artifactregistry.googleapis.com
cloudbuild.googleapis.com
run.googleapis.com
secretmanager.googleapis.com
logging.googleapis.com
monitoring.googleapis.com
sqladmin.googleapis.com
bigquery.googleapis.com
storage.googleapis.com
cloudkms.googleapis.com
servicenetworking.googleapis.com
dns.googleapis.com
)

# ==========================
# OPTIONAL FEATURES
# ==========================

CREATE_NETWORK=true
CREATE_BUDGET=false
CREATE_AUDIT_LOG_SINK=false

# ==========================
# BUDGET
# ==========================

BUDGET_AMOUNT="50"
BUDGET_CURRENCY="USD"
BUDGET_THRESHOLDS="0.5,0.9,1.0"

# ==========================
# BIGQUERY AUDIT LOGS
# ==========================

BQ_DATASET="audit_logs"